$EXPER;
*
def e24b04;
     exper_name = e24b04;
     exper_description = "ALMA+EHT VLBI April 2024 M87 + Sgr A* 260 GHz";
     PI_name = "EHTC";
     PI_email = not@an.address;
*    address:   The Event Horizon Telescope Collaboration
*               Global
*                
*                
*    phone:     TBD
*    during obs:TBD
*    fax:        
*
*    year, doy: 2024,  94
*    date     : Wed  3 Apr 2024
*    MJD      : 60403
     exper_nominal_start=2024y094d22h32m00s;
     exper_nominal_stop=2024y095d16h15m00s;
*
     target_correlator = HAYSTACK;
*
*    integr_time    :     1.000 s
*    number_channels:    64
*    number_antenna :  8
*    cross_polarize : Yes
*    weight_func    : UNIFORM
*    distrib_medium : FTP
*    distrib_format : FITS
*    source_pos_cat : STANDARD
*    distribute_to  : 
*                     Sub-bands 1 and 4 to MPIfR, 2 and 3 to Haystack
*
enddef;
*------------------------------------------------------------------------------
$MODE;
*
def band6-260;
     ref $PROCEDURES = Mode_01;
     ref $FREQ = 264500.00MHz1x2048MHz:Nn:Pv:Gl:Ax:Lm:Kt:Aa:Mg:Mm:Sw;
     ref $IF = LO@264484MHzLPolNoTone:Nn:Pv:Gl:Ax:Lm:Kt:Aa:Mg:Mm:Sw;
     ref $BBC = 1BBCs:Nn:Pv:Gl:Ax:Lm:Kt:Aa:Mg:Mm:Sw;
     ref $TRACKS = MARK5B.1Ch2bit1to1:Nn:Pv:Gl:Ax:Lm:Kt:Aa:Mg:Mm:Sw;
*    ref $HEAD_POS = DiskVoid <= obsolete definition
     ref $ROLL = NoRoll:Nn:Pv:Gl:Ax:Lm:Kt:Aa:Mg:Mm:Sw;
*    ref $PASS_ORDER = DiskVoid <= obsolete definition
     ref $PHASE_CAL_DETECT = NoDetect:Nn:Pv:Gl:Ax:Lm:Kt:Aa:Mg:Mm:Sw;
enddef;
